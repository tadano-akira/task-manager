{
  "name": "functions",
  "private": true,
  "version": "0.1.0",
  "engines": {
    "node": "20"
  },
  "main": "lib/src/index.js",
  "scripts": {
    "prebuild": "node scripts/copy-shared.mjs",
    "build": "npm run prebuild && tsc",
    "build:watch": "npm run prebuild && tsc --watch",
